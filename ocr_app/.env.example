# === Extraction Server ===
OCR_PORT=8090
OCR_HOST=0.0.0.0

# LLM endpoint for text parsing (digital PDFs)
# Works with vLLM, Ollama, or any OpenAI-compatible API
LLM_BASE_URL=http://localhost:8000/v1
# LLM_MODEL=  # auto-detected from endpoint if empty

# VLM endpoint for scans/TIFFs (optional — defaults to LLM_BASE_URL)
# Only needed if your VLM runs on a separate endpoint
# VLM_BASE_URL=http://localhost:8001/v1
VLM_MODEL=Qwen/Qwen2.5-VL-7B-Instruct

# Min chars to consider a PDF page "digital" (vs scanned)
MIN_TEXT_LENGTH=50

# === Streamlit UI ===
OCR_SERVICE_URL=http://localhost:8090
